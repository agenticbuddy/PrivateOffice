# PrivateOffice editor — Collabora ONLINE built FROM SOURCE (coolwsd + browser bundle),
# against the LibreOffice/Collabora Office CORE taken from our PINNED base image (same version,
# 26.04.1-4). The core is NOT built from source. Adapted from upstream
# online/docker/from-source-gh-action (build.sh + Dockerfile). See assisted_translate.md
# ("Целевой уровень") and editor/manifests/upstream.json.
#
# The PrivateOffice theme + full rebrand + l10n overrides are applied AT BUILD TIME: the theme and
# l10n live as data (branding-privateoffice.css, l10n/overrides/client/*.json) and the rebrand/code
# fixes edit the freshly-built files in place — no runtime DOM patching, no bolt-on override sheet.

ARG BASE=collabora/code@sha256:75859dc9f9084d1877ce36cf96ec86600f495bade33289c9cbc27e0a0ee23b81
ARG ONLINE_REPO=https://github.com/CollaboraOnline/online.mirror
ARG ONLINE_REF=cp-26.04.1-4

# ---------- Stage 1: build Collabora Online (coolwsd + browser) from source ----------
FROM ubuntu:24.04 AS builder
ARG ONLINE_REPO
ARG ONLINE_REF
ENV DEBIAN_FRONTEND=noninteractive TZ=Etc/UTC
WORKDIR /build

# Build deps (mirrors upstream from-source-gh-action/Dockerfile, online part only).
RUN apt-get update && apt-get -y install \
      ca-certificates wget curl git build-essential libtool autoconf automake pkg-config \
      libpng-dev libcap-dev libcap2-bin libssl-dev libpam-dev libzstd-dev libcppunit-dev \
      python3-polib python3-lxml npm fontconfig rsync \
 && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://deb.nodesource.com/setup_20.x -o /tmp/n.sh && bash /tmp/n.sh \
 && apt-get install -y nodejs && rm /tmp/n.sh

# Static poco (exactly as upstream).
RUN mkdir -p /build/builddir && cd /build/builddir \
 && wget -q https://pocoproject.org/releases/poco-1.12.5p2/poco-1.12.5p2-all.tar.gz \
 && tar xf poco-1.12.5p2-all.tar.gz && cd poco-1.12.5p2-all \
 && ./configure --static --no-tests --no-samples --no-sharedlibs --cflags="-fPIC" \
      --omit=Zip,Data,Data/SQLite,Data/ODBC,Data/MySQL,MongoDB,PDF,CppParser,PageCompiler,Redis,Encodings,ActiveRecord \
      --prefix=/build/poco \
 && make -j"$(nproc)" && make install

# Online source, pinned to the version that matches the base image's core.
# The monorepo is large (~2.3 GB working tree); retry the shallow clone — large clones over
# TLS occasionally drop mid-transfer ("GnuTLS recv error (-110) / early EOF").
RUN git config --global http.postBuffer 1048576000 \
 && for i in 1 2 3 4 5; do \
      git clone --depth=1 --branch "$ONLINE_REF" "$ONLINE_REPO" /build/online && break; \
      echo "clone attempt $i failed; retrying in 5s…"; rm -rf /build/online; sleep 5; \
    done \
 && test -d /build/online/.git

# PrivateOffice SOURCE patches: unified diffs in editor/patches/*.patch applied to the freshly
# cloned Online source before configure (source-level changes to coolwsd / the browser bundle).
# No-op when the dir holds no .patch file. A failed apply BREAKS the build on purpose. On re-pin
# of ONLINE_REF, rebase the patches against the new source. Catalogued in editor/manifests/patchset.json.
COPY patches /build/patches
RUN cd /build/online \
 && for p in /build/patches/*.patch; do \
      [ -e "$p" ] || continue; \
      echo "PrivateOffice: applying source patch $(basename "$p")"; \
      git apply --whitespace=nowarn --verbose "$p"; \
    done

# Engine (LibreOffice/Collabora Office core) from our PINNED base image — same version, not built.
# configure detects engine/instdir (the LO install) + engine/include (LOKit headers, in source).
COPY --from=collabora/code@sha256:75859dc9f9084d1877ce36cf96ec86600f495bade33289c9cbc27e0a0ee23b81 \
     /opt/collaboraoffice /build/online/engine/instdir

# Build coolwsd + the browser bundle from source (flags mirror upstream build.sh).
WORKDIR /build/online
RUN ./autogen.sh \
 && ./configure --prefix=/usr --sysconfdir=/etc --localstatedir=/var --enable-silent-rules \
      --disable-tests \
      --with-lokit-path=/build/online/engine/include \
      --with-lo-path=/opt/collaboraoffice \
      --with-poco-includes=/build/poco/include --with-poco-libs=/build/poco/lib \
 && make -j"$(nproc)"
RUN mkdir -p /build/instdir && cd /build/online && DESTDIR=/build/instdir make install

# Snapshot the UNMERGED, source-built client catalogs BEFORE the override merge below, into a
# non-served path that ships in the image. This is the true upstream baseline for the override
# overlap check (scripts/check-l10n-overrides.py): the exact catalog the merge writes into, NOT
# the base image's prebuilt browser dist (a different build that can drift). Kept outside
# browser/dist so it is never served as a web asset.
RUN mkdir -p /build/instdir/usr/share/coolwsd/upstream-l10n \
 && cp -a /build/instdir/usr/share/coolwsd/browser/dist/l10n/. /build/instdir/usr/share/coolwsd/upstream-l10n/

# Merge our client-catalog translation OVERRIDES (data) into the freshly-built ui-<lang>.json.
# This is the honest data layer (editor/l10n/overrides/client/<lang>.json) replacing the old
# inline-sed injection; override keys win (adds missing keys, corrects the few wrong ones).
COPY l10n/overrides/client /tmp/po-overrides
RUN set -e; for f in /tmp/po-overrides/*.json; do \
      lang="$(basename "$f" .json)"; cat="/build/instdir/usr/share/coolwsd/browser/dist/l10n/ui-${lang}.json"; \
      if [ -f "$cat" ]; then \
        python3 -c "import json,sys; b=json.load(open('$cat')); o=json.load(open('$f')); b.update(o); json.dump(b, open('$cat','w'), ensure_ascii=False)"; \
        echo "merged $(python3 -c "import json;print(len(json.load(open('$f'))))") keys into ui-${lang}.json"; \
      else echo "WARN: no catalog for ${lang} ($cat)"; fi; \
    done; rm -rf /tmp/po-overrides

# ---------- Stage 2: runtime = pinned base, with the customized from-source Online swapped in ----------
# The base already provides the matching engine (/opt/collaboraoffice), the cool user, the jail
# systemplate and capabilities; we overlay our freshly-built + customized Online artifacts on top.
FROM ${BASE} AS runtime
USER root
ARG DIST=/usr/share/coolwsd/browser/dist
ARG BUILD_ID=dev

# Bring in the from-source Online (coolwsd binaries, browser dist, etc.) + the built coolwsd.xml.
COPY --from=builder /build/instdir/usr/ /usr/
COPY --from=builder /build/instdir/etc/coolwsd/coolwsd.xml /etc/coolwsd/coolwsd.xml
# Provide our OWN empty (inert) branding.js. If left to coolwsd, it substitutes cool.html's
# %BRANDING_JS% placeholder AT SERVE TIME with <script src=".../branding.js"> WITHOUT our ?b=
# cache-bust — a 404 in the open-source build, and an already-cached browser (long max-age, same
# version-hash path) could replay a stale brand script. So we replace the placeholder ourselves
# below (PO-BRAND-011) so the tag is real, points at this empty file, and goes through the ?b= step.
RUN printf '%s\n' '/* PrivateOffice: intentionally empty branding script. Branding is applied via the folded theme and the product rebrand. */' > ${DIST}/branding.js

# --- PrivateOffice assets ---
COPY fonts/ ${DIST}/fonts/
COPY po-logo.svg ${DIST}/images/po-logo.svg
COPY po-toggle.js ${DIST}/po-toggle.js
# po-funcnames.js: generated {EnglishName -> LocalizedName} Calc function-name map
# (window.PO_FN_NAMES), consumed by the getLocalizedFuncName source patch (editor/patches/0001-*)
# so notebookbar function dropdowns show localized names AND insert in every locale. Same delivery
# as po-toggle.js — a parse-blocking <head> script that runs before the deferred bundle.js.
COPY po-funcnames.js ${DIST}/po-funcnames.js

# Fold the PrivateOffice glass theme into the editor's OWN stylesheet (bundle.css), correct on first
# paint — not a separate override sheet. The theme gate (po-toggle.js) is a same-origin external
# parse-blocking script (CSP is script-src 'self'); it sets data-po for the glass theme, classic
# sessions opt out via ?po_design.
COPY branding-privateoffice.css /tmp/po-theme.css
RUN cat /tmp/po-theme.css >> ${DIST}/bundle.css && rm /tmp/po-theme.css \
 && sed -i '/po-theme\.css/d; /po-theme-toggle/d; /po-toggle\.js/d; /po-funcnames\.js/d' ${DIST}/cool.html \
 && sed -i "s#</head>#<script id=\"po-theme-toggle\" src=\"%SERVICE_ROOT%/browser/%VERSION%/po-toggle.js\"></script></head>#" ${DIST}/cool.html \
 && sed -i "s#</head>#<script id=\"po-funcnames\" src=\"%SERVICE_ROOT%/browser/%VERSION%/po-funcnames.js\"></script></head>#" ${DIST}/cool.html

# Remove the engine's DEAD bare inline dark-theme <script> (CSP rejects inline; it never runs).
RUN sed -i '/<script>/{:a;N;/<\/script>/!ba;/Apply dark theme immediately/d;}' ${DIST}/cool.html

# Rebrand the product name + copyright everywhere (display strings, safe across JS/HTML/JSON/CSS).
# Phrases first, then the bare upstream word on data/markup files only (NOT bundle.js). The open-
# source build has no branding.js, so only admin-bundle.js gets the bare-word pass.
RUN PHRASES='s/Collabora Online Development Edition (CODE)/PrivateOffice/g; s/Collabora Online Development Edition/PrivateOffice/g; s/Collabora Online/PrivateOffice/g; s/Collabora Office/PrivateOffice/g; s/Collabora Productivity Limited/PrivateOffice/g; s/Collabora Productivity/PrivateOffice/g' \
 && grep -rIl 'Collabora' ${DIST} --include='*.js' --include='*.html' --include='*.json' --include='*.css' 2>/dev/null | xargs -r sed -i "$PHRASES" \
 && grep -rIl 'Collabora' ${DIST} --include='*.html' --include='*.json' --include='*.css' 2>/dev/null | xargs -r sed -i 's/Collabora/PrivateOffice/g' \
 && sed -i 's/Collabora/PrivateOffice/g' ${DIST}/admin-bundle.js

# Localize the ribbon group "more options" expander at source (de-concatenate aria/tooltip).
RUN sed -i "s#\"More options for \"+id#_(\"More options for {1}\").replace(\"{1}\",groupLabel\&\&groupLabel.textContent?groupLabel.textContent:id)#g" ${DIST}/bundle.js

# Localize the combobox dropdown accessible name (de-concatenate the fragment msgids).
RUN sed -i "s#dataAriaLabel?_(\"Open \")+dataAriaLabel+_(\" list\"):_(\"Open list\")#dataAriaLabel?_(\"Open {name}\").replace(\"{name}\",dataAriaLabel):_(\"Open list\")#" ${DIST}/bundle.js

# Neutralize every external upstream URL at source (no phone-home / identity leak).
# Case-insensitive so capitalized identity URLs (e.g. github.com/CollaboraOnline/online) are caught too.
RUN grep -rIli 'collabora' ${DIST} --include='*.js' --include='*.html' --include='*.json' --include='*.css' 2>/dev/null \
      | xargs -r sed -i -E 's|https?://[a-zA-Z0-9._/?=&:%~-]*[Cc]ollabora[a-zA-Z0-9./?=&:%~_-]*|about:blank|g' \
 && grep -rIl 'col\.la' ${DIST} --include='*.js' --include='*.html' --include='*.json' --include='*.css' 2>/dev/null \
      | xargs -r sed -i 's|https\?://col\.la[a-zA-Z0-9./?=&:%~_-]*|about:blank|g'

# Replace upstream logo image files with the PrivateOffice mark.
RUN for f in $(ls ${DIST}/images/ | grep -iE 'collabora|full-logo|lc_about|toolbar-bg-logo'); do \
      cp ${DIST}/images/po-logo.svg ${DIST}/images/$f; \
    done

# Provide the Paste Special context-menu icon the engine requests but upstream omits.
RUN cp ${DIST}/images/lc_paste.svg ${DIST}/images/lc_pastespecial.svg \
 && cp ${DIST}/images/dark/lc_paste.svg ${DIST}/images/dark/lc_pastespecial.svg \
 && chmod a+r ${DIST}/images/lc_pastespecial.svg ${DIST}/images/dark/lc_pastespecial.svg

# Don't request an empty images/ URL for icon-less entries (stray 404 guard).
RUN sed -i 's#getImageURL=function(imgName){var _a;#getImageURL=function(imgName){var _a;if(!imgName)return"";#' ${DIST}/bundle.js

# Privacy + rebrand of coolwsd's SERVE-TIME placeholders. Name -> PrivateOffice, product URL ->
# about:blank; empty feedback/welcome/buyproduct; disable auto-welcome. Also REPLACE the %BRANDING_JS%
# placeholder with our OWN <script .../branding.js> tag: this stops coolwsd injecting its own
# un-cache-busted tag at serve time, and routes branding.js through the ?b= step below so even an
# already-cached browser refetches it. The from-source build ships no welcome/ dir → that rm is a no-op.
RUN sed -i 's/%FEEDBACK_URL%//g; s/%WELCOME_URL%//g; s/%BUYPRODUCT_URL%//g; s/%AUTO_SHOW_WELCOME%/false/g; s/%PRODUCT_BRANDING_NAME%/PrivateOffice/g; s|%PRODUCT_BRANDING_URL%|about:blank|g' ${DIST}/cool.html \
 && sed -i 's#<!--%BRANDING_JS%-->#<script src="%SERVICE_ROOT%/browser/%VERSION%/branding.js"></script>#' ${DIST}/cool.html \
 && rm -rf ${DIST}/welcome ${DIST}/welcome.html ${DIST}/welcome.js \
 && chmod -R a+r ${DIST}/fonts ${DIST}/images

# Per-build cache-bust: stamp BUILD_ID into ver_suffix (fresh ETag) + ?b= on cool.html assets.
RUN sed -i "s#\(<ver_suffix [^>]*>\)</ver_suffix>#\1${BUILD_ID}</ver_suffix>#" /etc/coolwsd/coolwsd.xml
RUN sed -i -E "s#(%SERVICE_ROOT%/browser/%VERSION%/[A-Za-z0-9._/-]+\.(css|js|json))#\1?b=${BUILD_ID}#g" ${DIST}/cool.html

# Re-apply capabilities (lost when binaries were replaced) and regenerate the jail systemplate so
# it matches the from-source coolwsd.
RUN (setcap cap_fowner,cap_chown,cap_sys_chroot=ep /usr/bin/coolforkit-caps 2>/dev/null || true) \
 && (setcap cap_sys_admin=ep /usr/bin/coolmount 2>/dev/null || true) \
 && (chmod -R a+rX /usr/share/coolwsd/browser 2>/dev/null || true) \
 && (coolwsd-systemplate-setup /opt/cool/systemplate /opt/collaboraoffice >/dev/null 2>&1 || true)

USER cool
